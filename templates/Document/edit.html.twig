{# templates/document/edit.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}{{ document.title }}{% endblock %}

{% block body %}
    <div class="wrap">
        <div class="card">
            <h1 class="title">Bewerken Set: {{ document.title }}</h1>
            <p class="subtitle">Publiceer Symphonic eMotions muziek sets.</p>

            {% form_theme form 'forms/_theme.html.twig' %}
            {{ form_start(form, { attr: { id: 'document-form', enctype: 'multipart/form-data' } }) }}

            {# --- Set gegevens (Titel / Grid / BPM) --- #}
            <div class="section">
                <div class="grid grid-2">
                    <div class="grid">
                        {{ form_row(form.title) }}
                    </div>
                    <div class="grid">
                        {{ form_row(form.gridSize) }}
                        {{ form_row(form.setBPM) }}
                        {{ form_row(form.timeSignature) }}
                    </div>
                </div>
            </div>

            {# --- Assets --- #}
            <div class="section">
                <h2 class="section-title">Upload midi bestand</h2>
                <div class="grid">
                    <div>
                        {{ form_row(form.midiFiles, {
                            attr: form.midiFiles.vars.attr|merge({
                                class: (form.midiFiles.vars.attr.class|default('') ~ ' js-midi-upload')|trim,
                                'data-notice-target': 'midi-upload-notice'
                            })
                        }) }}
                        <div id="midi-upload-notice"></div>
                    </div>

                    {# ---------------------------
                   MIDI bestanden in project
                   - Parents bovenaan
                   - Gesplitste tracks (children) direct eronder
                   --------------------------- #}

                    {% macro render_chip(a, document, midiSummariesByAssetId, isChild, childLabel) %}
                        {% set summary = midiSummariesByAssetId[a.id] ?? null %}
                        {% set summaryError = (summary is iterable and summary.error is defined) ? summary.error : null %}

                        {% set midiUrl = path('doc_asset_download', { id: document.id, assetId: a.id }) %}
                        {% set previewId = 'midi-preview-' ~ a.id %}
                        {% set vizId     = 'midi-viz-' ~ a.id %}

                        <div class="chip{{ isChild ? ' chip-child' : '' }}">

                            {# ── Bovenste rij: naam + knoppen ── #}
                            <div class="chip-row">
                                <div class="chip-main chip-main-stack">
                                    <div class="chip-name-wrapper">
                                        {# Display mode (visible by default) #}
                                        <span class="chip-name-display">
                                            {% if isChild %}
                                                <span class="subtle" style="margin-right:6px;">↳</span>
                                                {% if childLabel %}<span class="subtle">{{ childLabel }}</span>{% endif %}
                                            {% endif %}
                                            {{ a.displayName ?? a.originalName }}
                                        </span>

                                        {# Edit mode (hidden by default) #}
                                        <div class="chip-name-edit" id="chip-edit-{{ a.id }}" hidden>
                                            <input
                                                type="text"
                                                class="rename-input"
                                                value="{{ a.displayName ?? a.originalName }}"
                                                data-asset-id="{{ a.id }}"
                                                data-document-id="{{ document.id }}"
                                                data-csrf-token="{{ csrf_token('rename-asset-' ~ a.id) }}"
                                            />
                                            <button type="button" class="btn-mini-icon" onclick="saveAssetRename({{ a.id }}, {{ document.id }})" title="Opslaan">✓</button>
                                            <button type="button" class="btn-mini-icon" onclick="cancelAssetRename({{ a.id }})" title="Annuleren">✕</button>
                                        </div>
                                    </div>

                                    <span class="chip-meta subtle chip-meta-below">
                                        ({% if a.size is not null %}{{ (a.size / 1024)|number_format(1, '.', ' ') }} KB{% else %}–{% endif %}
                                        {% if summary and not summaryError %}
                                        · {{ summary.trackCount }} track{{ summary.trackCount == 1 ? '' : 's' }}
                                        · {{ summary.getDurationFormatted() }}
                                        {% endif %})
                                        {% if summary and not summaryError %}
                                            {% if summary.simultaneousNoteCount > 0 %}
                                                <span class="badge-warning" title="{{ summary.simultaneousNoteCount }} noten starten gelijktijdig">
                                                    ⚠ {{ summary.simultaneousNoteCount }} gelijktijdig
                                                </span>
                                            {% else %}
                                                <span class="subtle" style="font-size:0.78em">(geen gelijktijdige noten)</span>
                                            {% endif %}
                                        {% endif %}
                                     </span>
                                </div>

                                <div class="chip-actions">
                                    {# 1. Preview button #}
                                    <button
                                            type="button"
                                            class="btn-mini"
                                            data-preview-id="{{ previewId }}"
                                            onclick="toggleMidiPreview('{{ previewId }}', this)"
                                            title="Preview en piano roll"
                                    >▶ Preview</button>

                                    {# 2. Stagger notes button (conditional) #}
                                    {% if summary and not summaryError and summary.simultaneousNoteCount > 0 %}
                                        <button
                                                type="button"
                                                class="btn-mini warning"
                                                data-url="{{ path('doc_asset_stagger_notes', { id: document.id, assetId: a.id }) }}"
                                                data-csrf="{{ csrf_token('stagger-notes-' ~ a.id) }}"
                                                onclick="staggerNotes(this.dataset.url, this.dataset.csrf)"
                                                title="Verschuif gelijktijdige noten elk 1 tick naar achteren"
                                        >Stagger noten</button>
                                    {% endif %}

                                    {# 3. Split tracks button (conditional) #}
                                    {% if (not isChild) and summary and not summaryError and summary.trackCount > 1 %}
                                        <button
                                                type="button"
                                                class="btn-mini"
                                                data-url="{{ path('doc_asset_split_tracks', { id: document.id, assetId: a.id }) }}"
                                                data-csrf="{{ csrf_token('split-tracks-' ~ a.id) }}"
                                                onclick="splitTracks(this.dataset.url, this.dataset.csrf)"
                                        >Split tracks</button>
                                    {% endif %}

                                    {# Error message (if any) #}
                                    {% if summaryError %}
                                        <span class="subtle">midi-analyse mislukt</span>
                                        {% if is_granted('ROLE_ADMIN') %}
                                            <code class="subtle">{{ summaryError }}</code>
                                        {% endif %}
                                    {% endif %}

                                    {# 4. Icon group: Edit, Download, Delete (always together) #}
                                    <div class="chip-actions-icons">
                                        {# Edit button for rename #}
                                        <button
                                                type="button"
                                                class="btn-mini-icon"
                                                onclick="toggleAssetRename({{ a.id }})"
                                                title="Hernoemen"
                                        >
                                            <svg class="icon" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M12 20h9"></path>
                                                <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L8 18l-4 1 1-4 11.5-11.5Z"></path>
                                            </svg>
                                        </button>

                                        {# Download button with SVG icon #}
                                        <a href="{{ midiUrl }}" class="btn-mini-icon" title="Download">
                                            <svg class="icon" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                                <polyline points="7 10 12 15 17 10"></polyline>
                                                <line x1="12" y1="15" x2="12" y2="3"></line>
                                            </svg>
                                        </a>

                                        {# Delete button with SVG icon #}
                                        <button
                                                type="button"
                                                class="btn-mini-icon danger"
                                                data-url="{{ path('doc_asset_delete', { id: document.id, assetId: a.id }) }}"
                                                data-csrf="{{ csrf_token('delete-asset-' ~ a.id) }}"
                                                data-name="{{ a.originalName }}"
                                                onclick="deleteAsset(this.dataset.url, this.dataset.csrf, this.dataset.name)"
                                                title="Verwijder"
                                        >
                                            <svg class="icon" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="3 6 5 6 21 6"></polyline>
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                <line x1="10" y1="11" x2="10" y2="17"></line>
                                                <line x1="14" y1="11" x2="14" y2="17"></line>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            {# ── Preview: midi-player + piano roll (verborgen tot toggle) ── #}
                            <div class="chip-preview" id="{{ previewId }}" hidden>
                                <midi-player
                                        src="{{ midiUrl }}"
                                        sound-font
                                        visualizer="#{{ vizId }}"
                                ></midi-player>
                                <midi-visualizer
                                        id="{{ vizId }}"
                                        type="piano-roll"
                                        src="{{ midiUrl }}"
                                ></midi-visualizer>
                            </div>

                        </div>
                    {% endmacro %}

                    {% import _self as midiui %}

                    <div>
                        <label class="label">MIDI bestanden in project</label>

                        {% set parents = assetsParents ?? [] %}

                        {% if parents|length %}
                            <div class="chips" style="margin-top:8px">

                                <style>
                                    .chip-child {
                                        margin-left: 18px;
                                        opacity: 0.96;
                                    }
                                    .chip-child .chip-name {
                                        font-size: 0.95em;
                                    }

                                    /* Info midi file onder naam, compact */
                                    .chip-main-stack{
                                        display: flex;
                                        flex-direction: column;
                                        align-items: flex-start; /* ← dit is de sleutel */
                                        gap: 2px;
                                        min-width: 0;
                                        line-height: 1.1;
                                    }
                                    .chip-meta-below{
                                        text-align: left;        /* extra expliciet */
                                        align-self: flex-start;  /* belt + suspenders */
                                    }

                                    /* optioneel maar handig: lange namen niet alles laten oprekken */
                                    .chip-name{
                                        white-space: nowrap;
                                        overflow: hidden;
                                        text-overflow: ellipsis;
                                        max-width: 100%;
                                    }

                                    /* Chip herstructurering: rij + uitklapbare preview */
                                    .chip {
                                        flex-direction: column;
                                        align-items: stretch;
                                        gap: 0;
                                        white-space: normal; /* override zodat preview niet op 1 regel wordt geperst */
                                    }
                                    .chip-row {
                                        display: flex;
                                        justify-content: space-between;
                                        align-items: center;
                                        white-space: nowrap;
                                        width: 100%;
                                    }
                                    .chip-preview {
                                        margin-top: 10px;
                                        width: 100%;
                                        white-space: normal;
                                    }
                                    .chip-preview[hidden] { display: none; }

                                    /* midi-player: aanpassen aan donker thema */
                                    midi-player {
                                        display: block;
                                        width: 100%;
                                        --player-button-size: 28px;
                                        --color-primary: #5865f2;
                                        --color-secondary: #3bcdf7;
                                    }
                                    /* Pianorol: donkere achtergrond + accent kleuren */
                                    midi-visualizer {
                                        display: block;
                                        width: 100%;
                                        margin-top: 6px;
                                        border-radius: 8px;
                                        overflow: hidden;
                                        --background-color: #070f1f;
                                        --black-key-color:  #1a2540;
                                        --white-key-color:  #0f1a30;
                                        --note-color:       #5865f2;
                                        --active-note-color: #3bcdf7;
                                    }
                                    /* Hoogte van de pianorol beperken */
                                    midi-visualizer svg {
                                        max-height: 220px;
                                        width: 100%;
                                    }

                                    .badge-warning {
                                        display: inline-block;
                                        font-size: 0.78em;
                                        color: #92400e;
                                        background: #fef3c7;
                                        border: 1px solid #f59e0b;
                                        border-radius: 4px;
                                        padding: 1px 5px;
                                        margin-top: 2px;
                                    }

                                    .btn-mini.warning {
                                        background: #fef3c7;
                                        border-color: #f59e0b;
                                        color: #92400e;
                                    }
                                    .btn-mini.warning:hover {
                                        background: #fde68a;
                                    }
                                </style>

                                {% for a in parents %}
                                    {{ midiui.render_chip(a, document, midiSummariesByAssetId, false, null) }}

                                    {% set kids = (assetsChildrenById[a.id] ?? []) %}
                                    {% if kids|length %}
                                        {% for c in kids %}
                                            {# Je kunt childLabel ook null laten. Dit is een compact labeltje. #}
                                            {% set childLabel = 'track' %}
                                            {{ midiui.render_chip(c, document, midiSummariesByAssetId, true, childLabel) }}
                                        {% endfor %}
                                    {% endif %}

                                {% endfor %}

                            </div>
                        {% else %}
                            <p class="subtle" style="margin-top:6px">
                                Nog geen bestanden naar de server verzonden. Upload één of meer .mid-bestanden.
                            </p>
                        {% endif %}
                    </div>

                </div>
            </div>

            {# --- LevelDurations custom UI (tegels) --- #}
            <div class="section">
                <h2 class="section-title">Aantal levels voor deze set</h2>

                <div class="ld-row align-items-center">
                    {# 1. Tegels #}
                    <div id="ld-tiles" class="ld-tiles" data-target="#ld-hidden-inputs"></div>

                    {# 2. Acties rechts naast de tegels #}
                    <div class="ld-actions">
                        <button type="button" class="btn-mini" id="ld-add">+ Toevoegen</button>
                        <button type="button" class="btn-mini secondary" id="ld-remove">
                            – Verwijder laatste
                        </button>
                    </div>

                    {# 3. Track toevoegen rechts uitgelijnd op dezelfde rij #}
                    <div class="ld-track-add">
                        <button type="button" class="btn" id="add-track">+ Track toevoegen</button>
                    </div>
                </div>

                {# Hidden inputs #}
                <div id="ld-hidden-inputs"
                     class="ld-hidden"
                     data-prototype="{{ form_widget(form.levelDurations.vars.prototype)|e('html_attr') }}"
                     data-index="{{ form.levelDurations|length }}">
                    {% for field in form.levelDurations %}
                        <div class="ld-item">
                            {{ form_widget(field) }}
                        </div>
                    {% endfor %}
                </div>

                {% do form.levelDurations.setRendered %}
            </div>

            {# --- Tracks (DocumentTrack) --- #}
            <div class="section">

                {# 1) Prototype track-kaart #}
                {% set track_proto %}
                    {% include 'Document/_track_card.html.twig' with {
                        trackForm:   form.tracks.vars.prototype,
                        index:       '__name__',
                        num:         '__num__',
                        isPrototype: true,
                        midiInfo:    {}
                    } only %}
                {% endset %}

                {# 2) Container met bestaande tracks #}
                <div id="tracks"
                     class="tracks"
                     data-index="{{ form.tracks|length }}"
                     data-prototype="{{ track_proto|e('html_attr') }}">

                    {% for trackForm in form.tracks %}
                        {% include 'Document/_track_card.html.twig' with {
                            trackForm:   trackForm,
                            index:       loop.index0,
                            num:         loop.index,
                            isPrototype: false,
                            midiInfo:    midiInfo
                        } only %}
                    {% else %}
                        <p class="subtle">Nog geen tracks. Voeg er één toe.</p>
                    {% endfor %}
                </div>
            </div>

            {# Markeer custom gerenderde velden #}
            {% do form.tracks.setRendered %}

            {# Render published alvast, maar bewaar in variabele. Hierdoor is hij "gerenderd" vóór form_rest. #}
            {% set publishedRow %}
                {{ form_row(form.published, {
                    attr: form.published.vars.attr|merge({ form: 'document-form' })
                }) }}
            {% endset %}

            {{ form_rest(form) }}
            {{ form_end(form, { render_rest: false }) }}

        </div>
    </div>

    {# --- Sticky/Fixed bottom bar OUTSIDE card/wrap --- #}
    <div class="bottom-bar">
        <div class="bottom-bar-inner">

            <div class="bottom-bar-flashes">
                {% for type, messages in app.flashes %}
                    {% for msg in messages %}
                        <div class="flash flash-{{ type }}">{{ msg }}</div>
                    {% endfor %}
                {% endfor %}
            </div>

            <div class="bottom-bar-actions">
                <div class="bottom-bar-published">
                    {{ publishedRow|raw }}
                    <a
                            href="{{ path('doc_api_json', { id: document.id }) }}"
                            title="Download laatst opgeslagen JSON voor deze set"
                            style="
                                padding-left: 4px;
                                text-decoration:none;
                                font-size: 13px;
                                color: var(--muted);
                                "
                    >⬇️<span style="padding-left: 10px;">Download</span></a>
                </div>

                <button class="btn" type="submit" form="document-form">Opslaan</button>
                <a class="btn secondary" href="{{ path('app_dashboard') }}">Terug</a>
            </div>

        </div>
    </div>
    {# html-midi-player: Tone.js + Magenta core + player component #}
    <script src="https://cdn.jsdelivr.net/combine/npm/tone@14,npm/@magenta/music@1.23.1/es6/core.js,npm/html-midi-player@1.5.0"></script>

    <script src="{{ asset('js/semLoopConfig.js?v=1') }}"></script>
    <script src="{{ asset('js/leveldurationsTracksAOI.js?v=1') }}" defer></script>
    <script src="{{ asset('js/loopLengthEditor.js?v=1') }}" defer></script>
    <script src="{{ asset('js/midiAssetSaveNotice.js?v=3') }}" defer></script>
    <script src="{{ asset('js/assetRename.js?v=1') }}" defer></script>
    <script src="{{ asset('js/effectsSettings.js?v=1') }}" defer></script>
    <script>
        window.EFFECT_PRESET_MAP = {{ allEffectPresetsMap|json_encode|raw }};

        function toggleMidiPreview(previewId, btn) {
            const panel = document.getElementById(previewId);
            if (!panel) return;
            const isHidden = panel.hasAttribute('hidden');
            if (isHidden) {
                panel.removeAttribute('hidden');
                btn.textContent = '■ Sluit';
                btn.classList.add('active');
            } else {
                // Pauzeer de player als die bestaat
                const player = panel.querySelector('midi-player');
                if (player && typeof player.stop === 'function') player.stop();
                panel.setAttribute('hidden', '');
                btn.textContent = '▶ Preview';
                btn.classList.remove('active');
            }
        }
    </script>

{% endblock %}
